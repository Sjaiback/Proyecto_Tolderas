# Cache control for Hostinger / Apache / LiteSpeed.
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType text/css "access plus 1 hours"
  ExpiresByType application/javascript "access plus 1 hours"
  ExpiresByType application/json "access plus 1 hours"
  ExpiresByType image/webp "access plus 1 month"
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "\.(html|htm|css|js|json)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
  <FilesMatch "\.(webp|jpg|jpeg|png|svg|woff|woff2)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

<IfModule mod_mime.c>
  AddType image/webp .webp
  AddType application/javascript .js
  AddType text/css .css
  AddType application/json .json
</IfModule>
